# ════════════════════════════════════════════════════════════════════════
# Telco CRM Platform — environment variable şablonu
#
# Bu dosya örnek/dokümantasyon amaçlıdır ve docker compose tarafından
# OTOMATİK yüklenmez. Gerçek değerleri kullanmak için bu dosyayı `.env`
# olarak kopyalayın ve değerleri doldurun:
#
#   cp .env.example .env
#
# `.env` dosyasını ASLA git'e commit etmeyin (gizli bilgi içerir).
# Değişken tanımlanmazsa, config dosyalarındaki güvenli olmayan
# yerel-geliştirme varsayılanları (postgres/eureka) devreye girer.
# ════════════════════════════════════════════════════════════════════════

# ──── PostgreSQL (her servisin kendi veritabanı) ────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring datasource / Flyway kimlik bilgileri (config-repo/*.yml tarafından okunur)
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ──── Eureka basic-auth (discovery-server + tüm client'lar) ────
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=eureka
